<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:UntitledTycoonGame.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UntitledTycoonGame.Views.MainMenu">
    
    <Design.DataContext>
        <vm:MainMenuViewModel/>
    </Design.DataContext>
    
    <UserControl.Background>
        <ImageBrush Source="/src/Assets/Textures/main_menu.png" Stretch="UniformToFill"/>
    </UserControl.Background>
    
    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4 4 4 8"/>
            <Setter Property="Width" Value="200"/>
        </Style>
    </UserControl.Styles>
    
    <StackPanel>
        <Border>
            <TextBlock Classes="h1" Text="Untitled Tycoon Game"/>
        </Border>
        <Button Click="OnPlayButtonClick">Play</Button>
        <Button Click="OnSettingsButtonClick">Settings</Button>
        <Button Click="OnCreditsButtonClick">Credits</Button>
        <Button Click="OnQuitButtonClick">Quit</Button>
    </StackPanel>
</UserControl>
