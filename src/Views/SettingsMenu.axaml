<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UntitledTycoonGame.Views.SettingsMenu">
    
    <DockPanel>
        <Border DockPanel.Dock="Top" Classes="Heading">
            <TextBlock Text="Settings"/>
        </Border>
        <TextBlock DockPanel.Dock="Top" FontSize="32" HorizontalAlignment="Center" Text="meow"></TextBlock>
        
        <StackPanel DockPanel.Dock="Bottom" FlowDirection="RightToLeft" Orientation="Horizontal">
            <Button
                Classes="SmallButton"
                Click="OnBackButtonClick"
                HotKey="Escape"
                VerticalAlignment="Bottom">
                Back</Button>
        </StackPanel>
    </DockPanel>
</UserControl>
